PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# Chrome extension origins are allowed automatically for DocFlow Recorder uploads.

AUTH_PROVIDER=jwt
JWT_ACCESS_TOKEN_SECRET=replace-me
JWT_REFRESH_TOKEN_SECRET=replace-me
JWT_ACCESS_TOKEN_TTL=1d
JWT_REFRESH_TOKEN_TTL=30d
LOGTO_ENDPOINT=https://your-tenant.logto.app
LOGTO_APP_ID=your-logto-app-id
LOGTO_APP_SECRET=your-logto-app-secret
LOGTO_API_RESOURCE=https://api.docflow.local
LOGTO_CALLBACK_URL=http://localhost:5173/callback
LOGTO_SIGN_IN_URL=
LOGTO_GITHUB_SIGN_IN_URL=
LOGTO_GITHUB_IDP_NAME=github

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_SCHEMA=public
SUPABASE_STORAGE_BUCKET=recording_screenshots
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS=604800

AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=DocFlow
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096

EXTENSION_UPLOAD_TOKEN_SECRET=replace-me
EXTENSION_UPLOAD_TOKEN_TTL=1d
EXTENSION_PUBLISH_SECRET=replace-me
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SETUP_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

{
    "name": "@docflow/backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "npx --yes @nestjs/cli@10.4.0 build",
        "start": "npx --yes @nestjs/cli@10.4.0 start",
        "start:dev": "npx --yes @nestjs/cli@10.4.0 start --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.32.0",
        "@nestjs/common": "^10.4.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-socket.io": "^10.4.0",
        "@supabase/supabase-js": "^2.57.4",
        "microsoft-cognitiveservices-speech-sdk": "^1.44.1",
        "@nestjs/swagger": "^7.4.0",
        "@nestjs/websockets": "^10.4.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "helmet": "^7.1.0",
        "jose": "^5.9.6",
        "jsonwebtoken": "^9.0.2",
        "jwks-rsa": "^3.1.0",
        "multer": "^1.4.5-lts.1",
        "openai": "^4.60.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.1",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.4.0",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/jest": "^29.5.13",
        "@types/multer": "^1.4.12",
        "@types/passport-jwt": "^4.0.1",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.0",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "moduleNameMapper": {
            "^@docflow/shared$": "<rootDir>/src/shared"
        },
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/main.ts"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node"
    }
}

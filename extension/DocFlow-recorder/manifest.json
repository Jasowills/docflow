{
  "manifest_version": 3,
  "name": "DocFlow",
  "version": "1.0.0.16",
  "description": "Capture workflows, generate docs with AI, and manage your documentation workspace.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "tabCapture",
    "offscreen",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/brand-icon.png",
      "48": "icons/brand-icon.png",
      "128": "icons/brand-icon.png"
    }
  },
  "icons": {
    "16": "icons/brand-icon.png",
    "48": "icons/brand-icon.png",
    "128": "icons/brand-icon.png"
  }
}
